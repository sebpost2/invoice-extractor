generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Receipt {
  id        String @id @default(cuid())
  sessionId String

  imageData     Bytes
  imageMimeType String

  vendorName     String?
  vendorRuc      String?
  documentType   String?
  documentNumber String?
  issueDate      DateTime?
  currency       String    @default("PEN")
  subtotal       Decimal?  @db.Decimal(12, 2)
  igv            Decimal?  @db.Decimal(12, 2)
  total          Decimal?  @db.Decimal(12, 2)
  items          Json?

  rawExtraction Json?
  extractionMs  Int?
  createdAt     DateTime @default(now())

  // Semantic embedding of "vendor + concatenated item descriptions",
  // computed by Voyage AI (voyage-3.5-lite, 1024 dims). Used for
  // similarity search at /search. See lib/embeddings.ts +
  // scripts/setup-pgvector.ts for the index setup.
  embedding Unsupported("vector(1024)")?

  @@index([sessionId, createdAt])
  @@index([issueDate])
  @@index([vendorRuc])
}
